{
  "manifest_version": 3,
  "name": "MZ Tools",
  "version": "3.0.0",
  "description": "Ferramentas internas MZ NET — registros, mapa, condomínios e escala",
  "permissions": ["tabs"],
  "action": {
    "default_title": "MZ Tools",
    "default_popup": "index.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
