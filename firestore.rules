rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function userData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    /** Perfil carregado e não desativado (mesma ideia dos modelos de O.S). */
    function isActiveUser() {
      return request.auth != null
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && userData().active != false;
    }

    /** Gerente/supervisor ou papel técnico — edição da escala e turnos. */
    function isScheduleEditor() {
      return isActiveUser()
        && (
          userData().isDev == true
          || userData().isAdmin == true
          || userData().hierarchy == 'gerente'
          || userData().hierarchy == 'supervisor'
        );
    }

    /** Leitura da escala do setor (ou dev/admin em qualquer setor). */
    function canAccessSectorSchedule(sectorField) {
      return userData().sector == sectorField
        || userData().isDev == true
        || userData().isAdmin == true;
    }

    /** Agente do helpdesk (chamados internos): função T.I, ou dev/admin. */
    function helpdeskAgent() {
      return isActiveUser()
        && (
          userData().isDev == true
          || userData().isAdmin == true
          || userData().isTi == true
        );
    }

    /** Setores com acesso ao ambiente de condomínios (financeiro fica de fora). */
    function condominioSectorAllowed() {
      return userData().sector in ['suporte', 'instalacao', 'cadastro', 'comercial'];
    }

    /** Consulta ao cadastro de condomínios: setores permitidos, ou dev/admin. */
    function canReadCondominios() {
      return isActiveUser()
        && (
          userData().isDev == true
          || userData().isAdmin == true
          || condominioSectorAllowed()
        );
    }

    /** Edição do cadastro de condomínios: gerente de setor permitido, ou dev/admin. */
    function isCondominioEditor() {
      return isActiveUser()
        && (
          userData().isDev == true
          || userData().isAdmin == true
          || (userData().hierarchy == 'gerente' && condominioSectorAllowed())
        );
    }

    /** Gestão ampla de upgrades (lista/export/dashboard/comissões no app). */
    function isUpgradeManager() {
      return isActiveUser()
        && (
          userData().isDev == true
          || userData().isAdmin == true
          || (
            userData().sector == 'suporte'
            && (
              userData().hierarchy == 'gerente'
              || userData().hierarchy == 'supervisor'
            )
          )
        );
    }

    match /users/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow write: if false;
    }

    /**
     * Cartão público mínimo (nome + foto) para exibição em telas compartilhadas
     * como a linha do tempo de chamados. Legível por qualquer usuário ativo;
     * cada usuário só escreve o próprio cartão (apenas displayName/photoURL).
     */
    match /usersPublic/{userId} {
      allow read: if isActiveUser();
      // Próprio usuário ou gerente/admin/dev (AdminUsersPage cria perfis antes do 1º login)
      allow write: if request.auth != null
        && (
          request.auth.uid == userId
          || (
            isActiveUser()
            && (
              userData().isDev == true
              || userData().isAdmin == true
              || userData().hierarchy == 'gerente'
            )
          )
        )
        && (
          !('displayName' in request.resource.data)
          || request.resource.data.displayName == null
          || request.resource.data.displayName is string
        )
        && (
          !('photoURL' in request.resource.data)
          || request.resource.data.photoURL == null
          || request.resource.data.photoURL is string
        )
        && (
          !('sector' in request.resource.data)
          || request.resource.data.sector is string
        )
        && (
          !('hierarchy' in request.resource.data)
          || request.resource.data.hierarchy is string
        );
    }

    /** Leituras de avisos por usuário (somente o próprio usuário). */
    match /users/{userId}/noticeReads/{noticeId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow create, update, delete: if request.auth != null && request.auth.uid == userId;
    }

    /**
     * Avisos do sistema (criados por gerente).
     *
     * Modelo:
     * - message: string
     * - authorUid: string
     * - authorName: string
     * - createdAt: timestamp
     * - target: { scope: 'all' | 'sector', sector?: string }
     * - active: bool
     */
    match /notices/{noticeId} {
      allow read: if isActiveUser()
        && resource.data.active == true
        && (
          resource.data.status == 'published'
          || !('status' in resource.data)
        )
        && resource.data.target is map
        && (
          resource.data.target.scope == 'all'
          || (
            resource.data.target.scope == 'sector'
            && resource.data.target.sector == userData().sector
          )
        );

      allow create: if isActiveUser()
        && (
          userData().isDev == true
          || userData().isAdmin == true
          || userData().hierarchy == 'gerente'
        )
        && request.resource.data.active == true
        && request.resource.data.status in ['draft', 'published']
        && request.resource.data.pinned is bool
        && request.resource.data.priority in ['normal', 'important', 'critical']
        && request.resource.data.message is string
        && request.resource.data.authorUid == request.auth.uid
        && request.resource.data.authorName is string
        && request.resource.data.createdAt is timestamp
        && request.resource.data.target is map
        && (
          request.resource.data.target.scope == 'all'
          || (
            request.resource.data.target.scope == 'sector'
            && request.resource.data.target.sector is string
          )
        )
        && (request.resource.data.startsAt == null || request.resource.data.startsAt is timestamp)
        && (request.resource.data.endsAt == null || request.resource.data.endsAt is timestamp)
        && request.resource.data.stats is map
        && request.resource.data.stats.readCount is int;

      allow update: if isActiveUser()
        && (
          userData().isDev == true
          || userData().isAdmin == true
          || userData().hierarchy == 'gerente'
        )
        && request.resource.data.authorUid == resource.data.authorUid
        && request.resource.data.createdAt == resource.data.createdAt
        && request.resource.data.authorName is string
        && request.resource.data.message is string
        && request.resource.data.target is map
        && request.resource.data.active is bool
        && request.resource.data.status in ['draft', 'published']
        && request.resource.data.pinned is bool
        && request.resource.data.priority in ['normal', 'important', 'critical']
        && request.resource.data.stats is map
        && request.resource.data.stats.readCount is int;

      allow delete: if isActiveUser() && userData().isDev == true;
    }

    match /osTemplates/{templateId} {
      allow read, write: if false;
    }

    /**
     * Upgrades / Roku — leitura ampla para usuários ativos (consulta de duplicidade
     * por cliente exige ver documentos de outros operadores). A UI restringe o que
     * cada perfil enxerga.
     */
    match /upgrades/{upgradeId} {
      allow read: if isActiveUser();

      allow create: if isActiveUser()
        && request.auth.token.email != null
        && request.resource.data.operadorId == request.auth.token.email;

      allow update: if isActiveUser()
        && (
          (
            resource.data.operadorId == request.auth.token.email
            && request.resource.data.operadorId == resource.data.operadorId
            && request.resource.data.operadorNome == resource.data.operadorNome
          )
          || isUpgradeManager()
        );

      allow delete: if isActiveUser()
        && (
          resource.data.operadorId == request.auth.token.email
          || isUpgradeManager()
        );
    }

    /** Auditoria de ações no registro de upgrades (somente criação pelo cliente). */
    match /logs/{logId} {
      allow create: if isActiveUser();
      allow read, update, delete: if false;
    }

    /** Turnos disponíveis por setor (rótulos/cores). */
    match /escalaTurnos/{sectorId} {
      allow read: if isActiveUser() && canAccessSectorSchedule(sectorId);
      allow create, update: if isScheduleEditor()
        && canAccessSectorSchedule(sectorId)
        && request.resource.data.shifts is list;
      allow delete: if isScheduleEditor() && canAccessSectorSchedule(sectorId);
    }

    /** Grade mensal: documento ID `{sector}_{yyyy-MM}`. */
    match /escalaMes/{mesId} {
      allow read: if isActiveUser()
        && resource.data.sector is string
        && resource.data.yearMonth is string
        && resource.data.days is map
        && canAccessSectorSchedule(resource.data.sector);

      allow create: if isScheduleEditor()
        && request.resource.data.sector is string
        && request.resource.data.yearMonth is string
        && request.resource.data.days is map
        && canAccessSectorSchedule(request.resource.data.sector);

      allow update: if isScheduleEditor()
        && resource.data.sector is string
        && request.resource.data.sector == resource.data.sector
        && request.resource.data.yearMonth is string
        && request.resource.data.days is map
        && canAccessSectorSchedule(resource.data.sector);

      allow delete: if isScheduleEditor()
        && resource.data.sector is string
        && canAccessSectorSchedule(resource.data.sector);
    }

    /**
     * Chamados internos (helpdesk estilo GLPI).
     *
     * Modelo do documento:
     * - title, description: string
     * - category: string; priority: 'baixa'|'normal'|'alta'|'critica'
     * - status: 'aberto'|'em_atendimento'|'aguardando_solicitante'|'resolvido'
     * - authorUid/authorName/authorEmail/authorSector
     * - assigneeUid/assigneeName (responsável do T.I, ou null)
     * - resolution: { text, byUid, byName, at } | null  (parecer resolutivo)
     * - createdAt/updatedAt/resolvedAt
     *
     * Regras:
     * - Leitura: o autor do chamado ou um agente do T.I.
     * - Criação: qualquer usuário ativo abre como `aberto`, sem responsável.
     * - Atualização: agente do T.I altera livremente (status, responsável,
     *   parecer); o autor só atualiza sem mexer em status/responsável/parecer.
     * - Encerrar (`resolvido`) exige agente do T.I e parecer resolutivo (texto).
     */
    match /tickets/{ticketId} {
      allow read: if isActiveUser()
        && (
          resource.data.authorUid == request.auth.uid
          || helpdeskAgent()
        );

      allow create: if isActiveUser()
        && request.resource.data.authorUid == request.auth.uid
        && request.resource.data.status == 'aberto'
        && request.resource.data.assigneeUid == null
        && request.resource.data.resolution == null
        && request.resource.data.title is string
        && request.resource.data.description is string
        && request.resource.data.category is string
        && request.resource.data.priority in ['baixa', 'normal', 'alta', 'critica']
        && request.resource.data.createdAt is timestamp;

      allow update: if isActiveUser()
        && request.resource.data.authorUid == resource.data.authorUid
        && request.resource.data.createdAt == resource.data.createdAt
        && (
          helpdeskAgent()
          || (
            resource.data.authorUid == request.auth.uid
            && request.resource.data.status == resource.data.status
            && request.resource.data.assigneeUid == resource.data.assigneeUid
            && request.resource.data.resolution == resource.data.resolution
          )
        )
        && (
          request.resource.data.status != 'resolvido'
          || (
            helpdeskAgent()
            && request.resource.data.resolution.text is string
          )
        );

      allow delete: if isActiveUser() && userData().isDev == true;

      /** Linha do tempo: solicitante e T.I podem comentar; sem editar/excluir. */
      match /comments/{commentId} {
        allow read: if isActiveUser()
          && (
            helpdeskAgent()
            || get(/databases/$(database)/documents/tickets/$(ticketId)).data.authorUid == request.auth.uid
          );

        allow create: if isActiveUser()
          && request.resource.data.authorUid == request.auth.uid
          && request.resource.data.text is string
          && request.resource.data.createdAt is timestamp
          && (
            helpdeskAgent()
            || get(/databases/$(database)/documents/tickets/$(ticketId)).data.authorUid == request.auth.uid
          );

        allow update, delete: if false;
      }
    }

    /**
     * Cadastro de condomínios (viabilidade/inviabilidade de fibra óptica).
     * Leitura: setores suporte/instalação/cadastro/comercial (ou dev/admin).
     * Edição: gerente desses setores (ou dev/admin).
     */
    match /condominios/{condId} {
      allow read: if canReadCondominios();
      allow create, update, delete: if isCondominioEditor();
    }

    /**
     * Agenda de visitas técnicas. Documento ID `{area}_{yyyy-MM-dd}`,
     * area em ['agenda', 'manutencao']. Cada documento é a grade do dia
     * (técnicos x horários) com células de agendamento e a sub-área de negados.
     *
     * v1: qualquer usuário ativo lê e edita (regras finas serão definidas depois).
     */
    match /agendaDias/{diaId} {
      allow read: if isActiveUser();
      allow create, update: if isActiveUser()
        && request.resource.data.area in ['agenda', 'manutencao']
        && request.resource.data.date is string
        && request.resource.data.slots is list
        && request.resource.data.tecnicos is list
        && request.resource.data.cells is map
        && request.resource.data.negados is list;
      allow delete: if isActiveUser() && userData().isDev == true;
    }

    /**
     * Configurações da agenda (legenda de cores por área).
     * Leitura: usuários ativos. Escrita: gerente (ou dev/admin).
     */
    match /agendaSettings/{settingId} {
      allow read: if isActiveUser();
      allow create, update, delete: if isActiveUser()
        && (
          userData().isDev == true
          || userData().isAdmin == true
          || (userData().sector == 'suporte' && userData().hierarchy == 'gerente')
        );
    }

    /**
     * Modelos de O.S. para casos atípicos sem formulário dedicado.
     * Leitura: qualquer usuário ativo do suporte (ou dev/admin).
     * Escrita: gerente (ou dev/admin).
     */
    match /modelos_os/{docId} {
      allow read: if isActiveUser()
        && (
          userData().isDev == true
          || userData().isAdmin == true
          || userData().sector == 'suporte'
        );

      allow create, update, delete: if isActiveUser()
        && (
          userData().isDev == true
          || userData().isAdmin == true
          || userData().hierarchy == 'gerente'
        );
    }

    /**
     * Histórico de O.S geradas por usuário.
     * Cada usuário lê, cria e exclui apenas os próprios registros.
     */
    match /osHistory/{entryId} {
      allow read, delete: if isActiveUser()
        && resource.data.uid == request.auth.uid;

      allow create: if isActiveUser()
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.slug is string
        && request.resource.data.title is string
        && request.resource.data.demandCategory is string
        && request.resource.data.preview is string
        && request.resource.data.clientName is string
        && request.resource.data.obs is string
        && request.resource.data.createdAt is timestamp;
    }

    /**
     * Mensagens rápidas da extensão MZ Cobertura.
     * Cada usuário lê e gerencia apenas os próprios itens.
     */
    match /mensagensRapidas/{userId}/itens/{itemId} {
      allow read, create, update, delete: if request.auth != null
        && request.auth.uid == userId;
    }

    /**
     * Contadores atômicos internos (ex.: numeração sequencial de chamados).
     * Leitura e escrita restritas a usuários ativos; campo lastNumber obrigatório.
     */
    match /counters/{counterId} {
      allow read: if isActiveUser();
      allow write: if isActiveUser()
        && request.resource.data.lastNumber is int;
    }

    /**
     * Validação de Mudanças de Endereço.
     *
     * Leitura: gerente (qualquer setor), isValidacao, isDev/isAdmin.
     * Criação: setor suporte (operadores também podem cadastrar), gerente, isValidacao, dev/admin.
     * Atualização: apenas quem pode validar (gerente, isValidacao, dev/admin).
     * Exclusão: apenas dev.
     */
    function canReadValidacao() {
      return isActiveUser()
        && (
          userData().isDev == true
          || userData().isAdmin == true
          || userData().isValidacao == true
          || userData().hierarchy == 'gerente'
        );
    }

    function canWriteValidacao() {
      return isActiveUser()
        && (
          userData().isDev == true
          || userData().isAdmin == true
          || userData().isValidacao == true
          || userData().hierarchy == 'gerente'
        );
    }

    function canCreateMudancaEndereco() {
      return isActiveUser()
        && (
          userData().isDev == true
          || userData().isAdmin == true
          || userData().isValidacao == true
          || userData().hierarchy == 'gerente'
          || userData().sector == 'suporte'
        );
    }

    match /mudancasEndereco/{docId} {
      allow read: if canReadValidacao();
      allow create: if canCreateMudancaEndereco();
      allow update: if canWriteValidacao();
      allow delete: if isActiveUser() && userData().isDev == true;
    }

    /**
     * Anotações pessoais (OneNote-like).
     * Cada usuário acessa apenas os próprios cadernos, seções e páginas.
     */
    match /users/{userId}/notebooks/{notebookId} {
      allow read, create, update, delete: if request.auth != null && request.auth.uid == userId && isActiveUser();

      match /sections/{sectionId} {
        allow read, create, update, delete: if request.auth != null && request.auth.uid == userId && isActiveUser();

        match /pages/{pageId} {
          allow read, create, update, delete: if request.auth != null && request.auth.uid == userId && isActiveUser();
        }
      }
    }

    /**
     * Presença dos usuários no chat interno.
     * Leitura: qualquer usuário autenticado (sem cross-doc read para garantir velocidade).
     * Escrita: apenas o próprio usuário.
     */
    match /presence/{uid} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == uid;
    }

    /**
     * Conversas do chat interno (1-a-1).
     * chatId = [uid1, uid2].sort().join('_') — UIDs do Firebase não contêm '_',
     * portanto chatId.split('_') retorna exatamente [uid1, uid2].
     * Verificar participação pelo chatId evita cross-doc reads e mantém latência < 100ms.
     */
    function isChatParticipant(chatId) {
      return request.auth != null
        && (chatId.split('_')[0] == request.auth.uid
            || chatId.split('_')[1] == request.auth.uid);
    }

    match /chats/{chatId} {
      /**
       * get: documento único — valida pelo chatId (sem resource.data necessário).
       * list: query de coleção — valida pelo campo participants do documento,
       *       permitindo ao Firestore garantir que a query
       *       where('participants','array-contains', uid) é segura.
       */
      allow get: if isChatParticipant(chatId);
      allow list: if request.auth != null
        && request.auth.uid in resource.data.participants;

      allow create: if request.auth != null
        && request.auth.uid in request.resource.data.participants
        && request.resource.data.participants.size() == 2;

      allow update: if isChatParticipant(chatId);

      /** Mensagens: participantes lêem e criam via chatId; sem cross-doc reads. */
      match /messages/{msgId} {
        allow read: if isChatParticipant(chatId);

        allow create: if isChatParticipant(chatId)
          && request.resource.data.senderId == request.auth.uid
          && request.resource.data.text is string
          && request.resource.data.createdAt is timestamp;

        allow update, delete: if false;
      }
    }

    /**
     * Pausas diárias dos operadores. Doc ID: `{YYYY-MM-DD}_{uid}`.
     * Campos: uid, displayName, date, horarioAgendado, inicioEfetivo, fimEfetivo.
     *
     * Leitura: qualquer usuário ativo (gerente precisa ver a equipe toda).
     * Definir horário (create/update horarioAgendado): gerente ou dev/admin.
     * Iniciar/encerrar própria pausa: o próprio usuário, desde que o doc já exista.
     */
    function isPausaManager() {
      return isActiveUser()
        && (
          userData().isDev == true
          || userData().isAdmin == true
          || userData().hierarchy == 'gerente'
        );
    }

    match /pausas/{pausaId} {
      allow read: if request.auth != null;

      // Gerente/admin/dev criam o documento com horarioAgendado
      allow create: if isPausaManager()
        && request.resource.data.uid is string
        && request.resource.data.date is string
        && request.resource.data.displayName is string;

      // Gerente/admin/dev atualizam qualquer campo;
      // o operador só atualiza o próprio doc (inicioEfetivo / fimEfetivo)
      allow update: if isActiveUser()
        && (
          isPausaManager()
          || (
            resource.data.uid == request.auth.uid
            && request.resource.data.uid == resource.data.uid
            && request.resource.data.date == resource.data.date
            && request.resource.data.displayName == resource.data.displayName
            && request.resource.data.horarioAgendado == resource.data.horarioAgendado
          )
        );

      allow delete: if isActiveUser() && userData().isDev == true;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
