rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Perfil: usuário autenticado só lê o próprio documento (ajuste quando houver admin/claims).
    match /users/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow write: if false;
    }

    // Templates de O.S: leitura por setor ou dev; escrita só via console/admin depois
    match /osTemplates/{templateId} {
      allow read: if request.auth != null
        && resource.data.active == true
        && (
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isDev == true
          || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.sector == resource.data.sector
        );
      allow write: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
