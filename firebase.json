{
  "functions": [
    {
      "source": "functions",
      "codebase": "default",
      "ignore": [
        "node_modules",
        ".git",
        "firebase-debug.log",
        "firebase-debug.*.log",
        "*.local"
      ],
      "predeploy": ["npm --prefix \"$RESOURCE_DIR\" run build"]
    }
  ],
  "hosting": {
    "public": "web/dist",
    "ignore": ["firebase.json", "**/.*", "**/node_modules/**"],
    "rewrites": [
      {
        "source": "/fbfunctions/manageUsersList",
        "function": {
          "functionId": "manageUsersList",
          "region": "southamerica-east1"
        }
      },
      {
        "source": "/fbfunctions/manageUsersCreate",
        "function": {
          "functionId": "manageUsersCreate",
          "region": "southamerica-east1"
        }
      },
      {
        "source": "/fbfunctions/manageUsersUpdate",
        "function": {
          "functionId": "manageUsersUpdate",
          "region": "southamerica-east1"
        }
      },
      {
        "source": "/fbfunctions/sectorRoster",
        "function": {
          "functionId": "sectorRoster",
          "region": "southamerica-east1"
        }
      },
      { "source": "**", "destination": "/index.html" }
    ]
  },
  "firestore": {
    "rules": "firestore.rules",
    "indexes": "firestore.indexes.json"
  }
}
