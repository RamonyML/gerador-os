# Copie para .env.local e preencha com o objeto do Firebase Console (Project settings > Your apps).
# Prefixo VITE_ é obrigatório para o Vite expor as variáveis no cliente.

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
# Opcional — só se usar Google Analytics no app
VITE_FIREBASE_MEASUREMENT_ID=

# Desenvolvimento local: "true" liga o app aos Firebase Emulators (auth/firestore/functions).
# Deixe vazio/false para apontar ao Firebase real.
VITE_USE_FIREBASE_EMULATORS=
