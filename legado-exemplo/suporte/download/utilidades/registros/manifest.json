{
  "manifest_version": 3,
  "name": "Mensagens Rápidas - Atendimento",
  "version": "1.0",
  "description": "Extensão para salvar e usar mensagens rápidas no atendimento via WhatsApp",
  "permissions": ["storage", "clipboardWrite"],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Mensagens Rápidas"
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
} 