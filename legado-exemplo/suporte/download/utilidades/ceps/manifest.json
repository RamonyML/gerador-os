{
  "manifest_version": 3,
  "name": "Pesquisa de Endereço - Uberlândia",
  "version": "1.0.0",
  "description": "Pesquisa rápida de endereços em Uberlândia-MG por logradouro ou CEP",
  "permissions": [
    "activeTab"
  ],
  "host_permissions": [
    "https://viacep.com.br/*",
    "https://*.viacep.com.br/*"
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Pesquisa de Endereço",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
} 